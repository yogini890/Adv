# MongoDB Atlas — database name must be mydb
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/mydb?retryWrites=true&w=majority

JWT_SECRET=your_long_random_secret_here

# Frontend URL(s) allowed by CORS — comma-separated for multiple
# Example: https://your-app.vercel.app,http://localhost:3000
CLIENT_URL=https://your-frontend-domain.com
